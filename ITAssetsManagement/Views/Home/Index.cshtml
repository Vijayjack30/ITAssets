@model ITAssetsManagement.Models.DashboardVM
@{
	ViewData["Title"] = "Asset Dashboard";
}
<style>
	.hero-card {
		background: linear-gradient(135deg, #1e3a8a, #2563eb);
		color: white;
		border-radius: 18px;
	}

	.status-card {
		border-radius: 14px;
		transition: all .2s ease-in-out;
	}

		.status-card:hover {
			transform: translateY(-5px);
		}

	.asset-tile {
		border-radius: 14px;
		transition: all .2s ease-in-out;
	}

		.asset-tile:hover {
			transform: translateY(-6px);
			background-color: #f8fafc;
		}

	.bg-donated {
		background-color: #7c3aed;
		color: #fff;
	}

	.bg-lost {
		background-color: #b91c1c;
		color: #fff;
	}
</style>
<h3 class="text-center mb-4">📊 Asset Dashboard</h3>
<!-- TOTAL ASSETS -->
<div class="row mb-5">
	<div class="col-12">
		<a asp-controller="Assets" asp-action="Index" class="text-decoration-none text-white" asp-route-fromHome="true">
			<div class="card hero-card shadow-lg">
				<div class="card-body text-center py-5">
					<h1 class="display-3 fw-bold">@Model.TotalAssets</h1>
					<p class="fs-5 mb-0">Total Assets in System</p>
				</div>
			</div>
		</a>
	</div>
</div>
<!-- WORKING / NOT WORKING -->
<div class="row mb-5">
	<div class="col-md-6">
		<a asp-controller="Assets" asp-action="Index" asp-route-condition="1" class="text-decoration-none text-white" asp-route-fromHome="true">
			<div class="card status-card bg-success text-white shadow">
				<div class="card-body d-flex justify-content-between align-items-center">
					<div>
						<h2>@Model.Working</h2>
						<small>Working Assets</small>
					</div>
					<i class="bi bi-check-circle-fill fs-1"></i>
				</div>
			</div>
		</a>
	</div>
	<div class="col-md-6">
		<a asp-controller="Assets" asp-action="Index" asp-route-condition="2" class="text-decoration-none text-dark" asp-route-fromHome="true">
			<div class="card status-card bg-warning text-dark shadow">
				<div class="card-body d-flex justify-content-between align-items-center">
					<div>
						<h2>@Model.NotWorking</h2>
						<small>Not Working Assets</small>
					</div>
					<i class="bi bi-exclamation-circle-fill fs-1"></i>
				</div>
			</div>
		</a>
	</div>
</div>
<!-- STATUS COUNTS -->
<h5 class="mb-3">Asset Status</h5>
<div class="row g-3 mb-5 text-center">
	<div class="col-md-2">
		<a asp-controller="Assets" asp-action="Index" asp-route-status="1" class="text-decoration-none text-white" asp-route-fromHome="true">
			<div class="card status-card bg-success text-white shadow">
				<div class="card-body">
					<i class="bi bi-box fs-4"></i>
					<h5>@Model.InStock</h5>
					<small>In Stock</small>
				</div>
			</div>
		</a>
	</div>
	<div class="col-md-2">
		<a asp-controller="Assets" asp-action="Index" asp-route-status="2" class="text-decoration-none text-dark" asp-route-fromHome="true">
			<div class="card status-card bg-warning text-dark shadow">
				<div class="card-body">
					<i class="bi bi-arrow-left-right fs-4"></i>
					<h5>@Model.Assigned</h5>
					<small>Assigned</small>
				</div>
			</div>
		</a>
	</div>
	<div class="col-md-2">
		@* <a asp-controller="AssetAssignments" asp-action="Index" asp-route-mode="InRepair" class="text-decoration-none text-white" asp-route-fromHome="true"> *@
		<a asp-controller="Assets" asp-action="Index" asp-route-status="6" class="text-decoration-none text-dark" asp-route-fromHome="true">
			<div class="card status-card bg-info text-white shadow">
				<div class="card-body">
					<i class="bi bi-tools fs-4"></i>
					<h5>@Model.InRepair</h5>
					<small>In Repair</small>
				</div>
			</div>
		</a>
	</div>
	<div class="col-md-2">
		<a asp-controller="Assets" asp-action="Index" asp-route-status="3" class="text-decoration-none text-white" asp-route-fromHome="true">
			<div class="card status-card bg-danger text-white shadow">
				<div class="card-body">
					<i class="bi bi-trash fs-4"></i>
					<h5>@Model.Disposed</h5>
					<small>Disposed</small>
				</div>
			</div>
		</a>
	</div>
	<div class="col-md-2">
		<a asp-controller="Assets" asp-action="Index" asp-route-status="4" class="text-decoration-none text-dark" asp-route-fromHome="true">
			<div class="card status-card bg-donated shadow">
				<div class="card-body">
					<i class="bi bi-gift fs-4"></i>
					<h5>@Model.Donated</h5>
					<small>Donated</small>
				</div>
			</div>
		</a>
	</div>
	<div class="col-md-2">
		<a asp-controller="Assets" asp-action="Index" asp-route-status="5" class="text-decoration-none text-white" asp-route-fromHome="true">
			<div class="card status-card bg-lost shadow">
				<div class="card-body">
					<i class="bi bi-exclamation-triangle-fill fs-4"></i>
					<h5>@Model.Lost</h5>
					<small>Lost / Stolen</small>
				</div>
			</div>
		</a>
	</div>
</div>
