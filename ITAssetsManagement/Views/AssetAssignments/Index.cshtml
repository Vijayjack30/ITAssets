@model List<AssetAssignmentVM>
@using Microsoft.AspNetCore.Mvc.Rendering
<h2 class="mb-3">Asset Assignment History</h2>
<form method="get" class="row g-3 mb-4">

    <div class="col-md-3">
        <label class="form-label">Asset ID</label>
        <select name="assetId" class="form-select" onchange="this.form.submit()">
            <option value="">-- All --</option>
            @foreach (var id in (List<string>)ViewBag.AssetIdList)
            {
                <option value="@id"
                        selected="@(Context.Request.Query["assetId"] == id)">
                    @id
                </option>
            }
        </select>
    </div>

    <div class="col-md-3">
        <label class="form-label">Assigned To</label>
        <select name="assignedTo" class="form-select" onchange="this.form.submit()">
            <option value="">-- All --</option>
            @foreach (var u in (SelectList)ViewBag.Users)
            {
                <option value="@u.Value"
                        selected="@(Context.Request.Query["assignedTo"] == u.Value)">
                    @u.Text
                </option>
            }
        </select>
    </div>

    <div class="col-md-3">
        <label class="form-label">Location</label>
        <select name="location"
                asp-items="ViewBag.LocationList"
                class="form-select"
                onchange="this.form.submit()">
            <option value="">-- All --</option>
        </select>
    </div>

    <div class="col-md-3 d-flex align-items-end">
<a asp-action="Index" class="btn btn-secondary">
	Reset
</a>
    </div>
</form>
<div class="custom-table-scroll">
	<table class="table table-bordered table-hover align-top text-nowrap" style="min-width: 1000px;">
		<thead class="custom-table-head text-left align-top">
			<tr>
				<th>Asset ID</th>
				<th>Assigned To</th>
				<th>Location</th>
				<th>Assigned Date</th>
				<th>Returned Date</th>
				<th>Comments</th>
				@* <th style="width:140px;">Action</th> *@
			</tr>
		</thead>
		<tbody>
			@if (!Model.Any())
			{
				<tr>
					<td colspan="7" class="text-center text-muted">
						No assignments found
					</td>
				</tr>
			}
			else
			{
				foreach (var item in Model)
				{
					<tr>
						<td class="fw-bold text-center">@item.AssetId</td>
						<td>@item.AssignedToDisplay</td>
						<td>@item.AssetLocation</td>
						<td class="text-center">
							@item.AssignedDate.ToString("dd-MM-yyyy HH:mm")
						</td>
						<td class="text-center">
							@(item.ReturnDate?.ToString("dd-MM-yyyy HH:mm") ?? "-")
						</td>
						<td>@(string.IsNullOrWhiteSpace(item.Comments) ? "-" : item.Comments)</td>
						<!--<td class="text-center">
							@* Assigned → In Repair *@
							@if (item.ReturnDate == null)
							{
									<a asp-action="Return"
									   asp-route-assetId="@item.AssetId"
									   asp-route-assignedDate="@item.AssignedDate"
									   class="btn btn-sm btn-warning"
									   onclick="return confirm('Move asset to In Repair?');">
										🔧 Move to Repair
									</a>
							}
							@* In Repair → Repair Completed *@
							else if (item.RepairCompletedDate == null)
							{
									<a asp-action="RepairCompleted"
									   asp-route-assetId="@item.AssetId"
									   asp-route-assignedDate="@item.AssignedDate"
									   class="btn btn-sm btn-success"
									   onclick="return confirm('Mark repair as completed?');">
										✅ Repair Completed
									</a>
							}
							@* Repair done *@
							else
							{
									<span class="badge bg-success">
										Repaired
									</span>
							}
							</td>-->
					</tr>
				}
			}
		</tbody>
	</table>
</div>