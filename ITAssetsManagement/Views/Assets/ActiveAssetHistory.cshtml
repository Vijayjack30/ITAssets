@model List<AssetAssignmentVM>
@using Microsoft.AspNetCore.Mvc.Rendering

<h2 class="mb-3">📜 Active Asset History</h2>

<form method="get" class="row g-3 mb-4">

    <div class="col-md-3">
        <label class="form-label">Asset ID</label>
        <select name="assetId" class="form-select" onchange="this.form.submit()">
            <option value="">-- All --</option>
            @foreach (var id in (List<string>)ViewBag.AssetIdList)
            {
                <option value="@id"
                        selected="@(Context.Request.Query["assetId"] == id)">
                    @id
                </option>
            }
        </select>
    </div>

    <div class="col-md-3">
        <label class="form-label">Assigned To</label>
        <select name="assignedTo" class="form-select" onchange="this.form.submit()">
            <option value="">-- All --</option>
            @foreach (var u in (SelectList)ViewBag.Users)
            {
                <option value="@u.Value"
                        selected="@(Context.Request.Query["assignedTo"] == u.Value)">
                    @u.Text
                </option>
            }
        </select>
    </div>

    <div class="col-md-3">
        <label class="form-label">Location</label>
        <select name="location"
                asp-items="ViewBag.LocationList"
                class="form-select"
                onchange="this.form.submit()">
            <option value="">-- All --</option>
        </select>
    </div>

    <div class="col-md-3 d-flex align-items-end">
        <a asp-action="ActiveAssetHistory" class="btn btn-secondary">
            🔄 Reset
        </a>
    </div>
</form>

<div class="custom-table-scroll">
    <table class="table table-bordered table-hover align-top text-nowrap" style="min-width: 1000px;">
        <thead class="custom-table-head text-left align-top">
        <tr>
            <th>Asset ID</th>
            <th>Assigned To</th>
            <th>Location</th>
            <th>Assigned Date</th>
            <th>Comments</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="5" class="text-center text-muted">
                    No active assignments
                </td>
            </tr>
        }
        else
        {
            foreach (var item in Model)
            {
                <tr>
                    <td class="fw-bold">@item.AssetId</td>
                    <td>@item.AssignedToDisplay</td>
                    <td>@item.AssetLocation</td>
                    <td>@item.AssignedDate.ToString("dd-MM-yyyy HH:mm")</td>
                    <td>@item.Comments</td>
                </tr>
            }
        }
    </tbody>
</table>
</div>


                
